---
import { getEntry } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/archive/');
}

const entry = await getEntry('post', slug!);

if (!entry || entry.data.archived !== true) {
  return Astro.redirect('/404');
}

const { Content } = await entry.render();

import Salawat from '../../components/Salawat.astro';
import GregDate from '../../components/GregDate.astro';
import HijriDate from '../../components/HijriDate.astro';

const components = {
  Salawat,
  HijriDate,
  GregDate,
};
---

<PostLayout {...entry.data}>
  <Content components={components} />
</PostLayout>
